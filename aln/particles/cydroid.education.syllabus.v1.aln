fields.default	5
fields.description	Number of modules.

fields.id	module_1_title
fields.type	string
fields.default	"Introduction to Soul Guardrails"
fields.description	Module 1 title.

fields.id	module_2_title
fields.type	string
fields.default	"NEU Budgets and Psych-Risk"
fields.description	Module 2 title.

fields.id	module_3_title
fields.type	string
fields.default	"ROW Ledger Integrity"
fields.description	Module 3 title.

fields.id	module_4_title
fields.type	string
fields.default	"Ecological Restoration Metrics"
fields.description	Module 4 title.

fields.id	module_5_title
fields.type	string
fields.default	"Community Governance"
fields.description	Module 5 title.

fields.id	certification_required
fields.type	bool
fields.default	true
fields.description	Certification required for operators.

